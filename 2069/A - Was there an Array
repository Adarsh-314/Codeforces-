#include <bits/stdc++.h>
using namespace std;
void solve() {
    int n;
    cin>>n;
    vector<int>v(n);
    for(int i=0; i<n-2; i++) {
        cin>>v[i];
    }
    for(int i=0; i<n-4; i++) {
        if(v[i]==1 && v[i+1]==0 && v[i+2]==1) {
            cout<<"NO"<<endl;
            return;
        }
    }
    cout<<"YES"<<endl;
    return;
}
int main() {
ios_base:: sync_with_stdio(false);
cin.tie(NULL);
int t;
cin>>t;
while(t--) {
solve ();
}
    
return 0;
}